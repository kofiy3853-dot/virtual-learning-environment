# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://localhost:27017/lms
MONGO_URI_TEST=mongodb://localhost:27017/lms_test

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS, password reset emails, etc.)
CLIENT_URL=http://localhost:3000

# AI Providers (at least one required for AI features)
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
OLLAMA_API_KEY=

# Email / SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_EMAIL=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM_NAME=UniLearn
SMTP_FROM_EMAIL=noreply@unilearn.edu

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate Limiting (optional - defaults in constants.js)
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000
# RATE_LIMIT_GLOBAL_MAX=300
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=50

# Logging
LOG_LEVEL=info